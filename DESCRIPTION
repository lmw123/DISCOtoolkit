Type: Package
Package: DISCOtoolkit
Title: R Client for the DISCO Single-Cell RNA-seq Platform
Version: 3.0.0
Authors@R: c(
  person(given = "Mengwei", family = "Li",
         email = "li_mengwei@immunol.a-star.edu.sg",
         role = c("cre", "aut")),
  person(given = "Jinmiao", family = "Chen",
         email = "chen_jinmiao@immunol.a-star.edu.sg",
         role = "ths")
